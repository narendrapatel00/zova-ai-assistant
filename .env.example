# Custom Path to config.yaml (optional, defaults to config/config.yaml)
ZOVA_CONFIG_PATH=config/config.yaml

# System Environment (development/production)
ZOVA_ENV=development

# Logging level override (DEBUG/INFO/WARNING/ERROR)
ZOVA_LOG_LEVEL=INFO

# Ollama Endpoint Configuration (For Phase 2)
OLLAMA_API_BASE=http://localhost:11434
